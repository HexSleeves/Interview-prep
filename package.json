{
  "name": "interview-prep",
  "private": true,
  "type": "module",
  "module": "src/cli/index.ts",
  "scripts": {
    "run": "bun . run",
    "init:solutions": "bun scripts/init-solutions.ts",
    "new-problem": "bun scripts/new-problem.ts",
    "cli": "bun .",
    "list": "bun . list",
    "check": "bun . check --all",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint . --deny-warnings",
    "lint:fix": "oxlint . --fix",
    "typecheck": "bunx tsc --noEmit",
    "docs:problems": "bun scripts/generate-problem-docs.ts",
    "test:harness": "bun test",
    "test:problems": "bun . check --all",
    "test": "bun run format:check && bun run lint && bun run typecheck && bun test && bun . check --all",
    "test:bst": "bun . check --domain binary-search-tree",
    "test:frequency": "bun . check --domain frequency",
    "test:prefix": "bun . check --domain prefix-sum",
    "test:window": "bun . check --domain sliding-window",
    "dev": "bun --hot src/server/index.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "bun-plugin-tailwind": "^0.1.2",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "tailwindcss": "^4.2.4"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.93.0",
    "@monaco-editor/react": "^4.7.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  }
}
