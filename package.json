{
  "name": "interview-prep",
  "module": "src/cli.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "cli": "bun run src/cli.ts",
    "list": "bun run src/cli.ts list",
    "test": "bun run src/cli.ts run --all",
    "test:bst": "bun run src/cli.ts run --domain binary-search-tree",
    "test:frequency": "bun run src/cli.ts run --domain frequency",
    "test:prefix": "bun run src/cli.ts run --domain prefix-sum",
    "test:window": "bun run src/cli.ts run --domain sliding-window",
    "format": "bunx biome format --write",
    "format:files": "bunx biome format --write --",
    "lint": "bunx biome lint --write",
    "lint:files": "bunx biome lint --write --",
    "check": "bunx biome check --write",
    "check:files": "bunx biome check --write --",
    "typecheck": "bunx tsc --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.12",
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
